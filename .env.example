DB_HOST=127.0.0.1
DB_USERNAME=postgres
DB_PASSWORD=postgres
VITE_API_BASE_URL=http://localhost:8080

# JWT signing secret - MUST be overridden with a long random value in production
JWT_SECRET=dev-only-secret-key-please-change-in-production-01234567890123456789
JWT_EXPIRATION_MS=86400000

# Origins allowed to call the API / connect to the WebSocket
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Default Leader account, seeded automatically on first startup
SEED_LEADER_USERNAME=leader
SEED_LEADER_PASSWORD=leader123
SEED_LEADER_FULLNAME=Truong nhom
